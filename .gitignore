# Built-in ignores
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
# Per-machine run config and session state, not shared project config - committing these would
# leak each contributor's last-selected device/AI-assistant opt-in/approval-state UUIDs into
# everyone else's checkout.
/.idea/deploymentTargetSelector.xml
/.idea/studiobot.xml
/.idea/planningMode.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# Roborazzi screenshots/videos (docs/user-guide.md's illustrations, `app/src/test/.../ui/
# *ScreenshotTest.kt`) regenerate on every `./gradlew testDebugUnitTest` - ignored by default so
# routine UI changes don't churn binary diffs into every commit. Un-ignore a specific file with an
# explicit `!` line below once it's actually embedded in docs/user-guide.md (i.e. once its
# TutorialTopic exists in `tutorial/TutorialTopic.kt`) - see CONTRIBUTING.md's "Test coverage"
# section for the full "wire in a screenshot" steps. New topics are gitignored (generated locally,
# not shipped) until deliberately wired in this way.
docs/images/generated/screenshots/*
docs/images/generated/videos/*
!docs/images/generated/screenshots/bpm-drag-scrub.png
!docs/images/generated/screenshots/bpm-drag-scrub-boundary.png
!docs/images/generated/screenshots/bpm-unit-entry-dialog.png
!docs/images/generated/screenshots/tap-tempo.png
!docs/images/generated/screenshots/hold-momentary-staging.png
!docs/images/generated/screenshots/hold-sticky-latch.png
!docs/images/generated/screenshots/time-signature-drag-scrub.png
!docs/images/generated/screenshots/bar-queue-management.png
