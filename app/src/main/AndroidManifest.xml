<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to access the Glyph Matrix on supported Nothing devices -->
    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <!-- MIDI clock sync is optional - the app works fine on devices/builds without MIDI support -->
    <uses-feature
        android:name="android.software.midi"
        android:required="false" />

    <!-- Persistent playback (Settings -> Playback, opt-in, off by default): a foreground service
         that keeps the metronome running through backgrounding/screen-lock/Glyph Toy unbind
         instead of implicitly stopping. POST_NOTIFICATIONS and the battery-optimization exemption
         are both requested opportunistically, never required - the service still runs at
         foreground priority without them, just without a visible notification / the strongest
         OEM-level exemption. See docs/publication_checklist.md and PersistentPlaybackService. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".QMetronomeApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Qmetronome">

        <meta-data
            android:name="NothingKey"
            android:value="test" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Qmetronome">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Glyph Toy: tempo/beat visualizer -->
        <service
            android:name=".glyph.MetronomeGlyphService"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.nothing.glyph.TOY" />
            </intent-filter>

            <meta-data
                android:name="com.nothing.glyph.toy.name"
                android:resource="@string/toy_name" />
            <meta-data
                android:name="com.nothing.glyph.toy.image"
                android:resource="@drawable/toy_preview" />
            <meta-data
                android:name="com.nothing.glyph.toy.summary"
                android:resource="@string/toy_summary" />
            <meta-data
                android:name="com.nothing.glyph.toy.longpress"
                android:value="1" />
        </service>

        <!-- Virtual MIDI clock input: lets other apps (DAWs, loopers, sequencers) on the same
             device send this app MIDI Clock with no hardware or pairing required. -->
        <service
            android:name=".midi.VirtualMidiClockService"
            android:exported="true"
            android:permission="android.permission.BIND_MIDI_DEVICE_SERVICE">
            <intent-filter>
                <action android:name="android.media.midi.MidiDeviceService" />
            </intent-filter>

            <meta-data
                android:name="android.media.midi.MidiDeviceService"
                android:resource="@xml/midi_device_info" />
        </service>

        <!-- Persistent playback: a quiet foreground service, started/stopped only while
             Settings -> Playback's "Persistent playback" is on and the metronome is actually
             playing (see QMetronomeApp). "specialUse" rather than "mediaPlayback" since this can
             be meaningful with the audible click off (Glyph-only practice) - mediaPlayback's
             policy assumes genuinely continuous audio. -->
        <service
            android:name=".engine.PersistentPlaybackService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FOREGROUND_SERVICE_TYPE"
                android:value="Keeps precise metronome timing/click running while backgrounded or screen-locked, the same standing use as dedicated metronome/tuner/timer apps" />
        </service>

        <!-- Home screen widget: BPM + play/stop, event-driven updates only. Must be exported -
             the launcher/system process delivers APPWIDGET_UPDATE from outside this app. -->
        <receiver
            android:name=".widget.MetronomeWidgetReceiver"
            android:exported="true"
            tools:ignore="ExportedReceiver">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/metronome_widget_info" />
        </receiver>

    </application>

</manifest>